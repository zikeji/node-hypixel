{
  "entryPoints": ["./src/index.ts"],
  "out": "./docs/api",
  "plugin": ["typedoc-plugin-markdown", "typedoc-vitepress-theme"],
  "readme": "none",
  "excludePrivate": true,
  "excludeProtected": true,
  "excludeExternals": true,
  "disableSources": true,
  "hideGenerator": true,
  "categorizeByGroup": true,
  "categoryOrder": ["Public", "API", "*", "Custom", "Other"],
  "exclude": ["**/node_modules/**"],
  "docsRoot": "./docs",
  "intentionallyNotExported": [
    "SkyBlockProfileMember",
    "ResultObject",
    "FlatResultArray",
    "ResultArray",
    "SkyBlockAuction",
    "Player",
    "Guild",
    "SkyBlockProfile",
    "ClientEvents",
    "OmitRespectingRemapping",
    "RateLimitData",
    "ElectionCurrent",
    "ElectionMayor",
    "SkyBlockMuseumMember"
  ]
}
