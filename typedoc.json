{
  "entryPoints": [
    "./src/index.ts",
    "./src/types/Augmented/Player.ts",
    "./src/types/Augmented/Guild.ts",
    "./src/types/Augmented/SkyBlock/Profile.ts",
    "./src/types/Augmented/SkyBlock/ProfileMember.ts",
    "./src/types/Augmented/SkyBlock/Auction.ts",
    "./src/types/Augmented/SkyBlock/Museum.ts",
    "./src/types/Augmented/Resources/SkyBlock/Election.ts",
    "./src/Client.ts",
    "./src/types/RateLimitData.ts"
  ],
  "out": "./docs/api",
  "plugin": ["typedoc-plugin-markdown", "typedoc-vitepress-theme"],
  "readme": "none",
  "excludePrivate": true,
  "excludeProtected": true,
  "excludeExternals": true,
  "disableSources": true,
  "hideGenerator": true,
  "categorizeByGroup": true,
  "categoryOrder": ["Public", "API", "*", "Custom", "Other"],
  "exclude": ["**/node_modules/**"],
  "docsRoot": "./docs",
  "intentionallyNotExported": [
    "ResultObject",
    "FlatResultArray",
    "ResultArray",
    "OmitRespectingRemapping",
    "ClientEvents"
  ]
}
