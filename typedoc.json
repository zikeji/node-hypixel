{
  "entryPoints": ["./src/index.ts"],
  "out": "./docs/api",
  "plugin": ["typedoc-plugin-markdown", "typedoc-vitepress-theme"],
  "readme": "none",
  "excludePrivate": true,
  "excludeProtected": true,
  "excludeExternals": true,
  "disableSources": true,
  "hideGenerator": true,
  "categorizeByGroup": true,
  "categoryOrder": ["Public", "API", "*", "Custom", "Other"],
  "exclude": ["**/node_modules/**"],
  "docsRoot": "./docs",
  "intentionallyNotExported": [
    "SkyBlockProfileMember",
    "ResultObject",
    "BoostersResponse",
    "CountsResponse",
    "PunishmentStatsResponse",
    "GuildResponse",
    "FlatResultArray",
    "HousingHouseResponse",
    "PlayerResponse",
    "ResultArray",
    "SkyblockAuctionsEndedResponse",
    "SkyblockBazaarResponse",
    "SkyblockNewsResponse",
    "SkyblockProfileResponse",
    "SkyBlockAuction",
    "SkyblockAuctionsResponse",
    "SkyblockProfilesResponse",
    "ResourcesSkyblockBingoResponse",
    "ResourcesSkyblockCollectionsResponse",
    "ResourcesSkyblockElectionResponse",
    "SkyBlockItem",
    "ResourcesSkyblockSkillsResponse",
    "ResourcesVanityCompanionsResponse",
    "ResourcesVanityPetsResponse",
    "Player",
    "Guild",
    "SkyBlockProfile",
    "ClientEvents",
    "OmitRespectingRemapping",
    "LeaderboardsResponse",
    "ResourcesGuildsAchievementsResponse",
    "RecentGamesResponse",
    "ResourcesAchievementsResponse",
    "ResourcesChallengesResponse",
    "ResourcesGamesResponse",
    "ResourcesQuestsResponse",
    "SkyblockFiresalesResponse",
    "SkyblockAuctionResponse",
    "SkyblockBingoResponse",
    "SkyblockGardenResponse",
    "SkyblockMuseumResponse",
    "ResourcesSkyblockItemsResponse",
    "StatusResponse",
    "RateLimitData"
  ]
}
